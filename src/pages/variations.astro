---
import BaseLayout from '../layouts/BaseLayout.astro';
import VariationToggle from '../components/VariationToggle';
import SafetyBanner from '../components/SafetyBanner';
import { commonVariations } from '../data/variations';
---

<BaseLayout title="House Rules — Buffalo Drinking Game">
  <section class="py-12 md:py-16">
    <div class="max-w-3xl mx-auto px-4">
      <h1 class="text-3xl md:text-4xl font-extrabold text-buffalo-dark text-center mb-3">
        House Rules
      </h1>
      <p class="text-center text-buffalo-gray mb-10 max-w-lg mx-auto">
        The official rules are sacred. But every crew adds their own spin.
        Here are the most popular twists — just sort them out before someone's
        three drinks deep and lawyering their way out of a chug.
      </p>

      <div class="space-y-3 mb-12">
        {commonVariations.map((variation) => (
          <VariationToggle variation={variation} client:visible />
        ))}
      </div>

      <div class="bg-buffalo-light rounded-xl p-6 text-center mb-8">
        <h3 class="font-bold text-buffalo-dark mb-2">
          Got a house rule we missed?
        </h3>
        <p class="text-buffalo-gray text-sm mb-4">
          Buffalo's been played around the world for decades. Every group
          brings something unhinged. The only real rule: agree before you play.
          The second real rule: no take-backs.
        </p>
        <a
          href="/rules"
          class="inline-block px-6 py-3 bg-buffalo-primary text-white font-bold rounded-xl hover:bg-buffalo-secondary transition-colors"
        >
          Back to the Official Rules
        </a>
      </div>

      <SafetyBanner />
    </div>
  </section>
</BaseLayout>
