---
import BaseLayout from '../layouts/BaseLayout.astro';
import RuleCard from '../components/RuleCard';
import HandDemo from '../components/HandDemo';
import SafetyBanner from '../components/SafetyBanner';
import { officialRules } from '../data/rules';
---

<BaseLayout title="Official Rules — Buffalo Drinking Game">
  <section class="py-12 md:py-16">
    <div class="max-w-3xl mx-auto px-4">
      <h1 class="text-3xl md:text-4xl font-extrabold text-buffalo-dark text-center mb-3">
        The Only Rules That Matter
      </h1>
      <p class="text-center text-buffalo-gray mb-10 max-w-lg mx-auto">
        Four rules. Memorize them. If your group plays differently, that's a
        house rule — check the <a href="/variations" class="text-buffalo-primary hover:underline font-medium">variations page</a>. But these? These are law.
      </p>

      <div class="space-y-4 mb-12">
        {officialRules.map((rule, i) => (
          <RuleCard rule={rule} index={i} />
        ))}
      </div>

      <div class="mb-12">
        <h2 class="text-2xl font-bold text-buffalo-dark text-center mb-4">
          Test Yourself
        </h2>
        <p class="text-center text-buffalo-gray mb-6 text-sm">
          Right-handed? Tap each hand and see if you'd survive.
        </p>
        <HandDemo client:visible dominantHand="right" />
      </div>

      <div class="bg-buffalo-light rounded-xl p-6 text-center mb-8">
        <h3 class="font-bold text-buffalo-dark mb-2">
          Your group plays differently?
        </h3>
        <p class="text-buffalo-gray text-sm mb-4">
          Cool. Just make sure everyone agrees before the first drink.
          We've catalogued the most common house rules so you don't have to argue about it.
        </p>
        <a
          href="/variations"
          class="inline-block px-6 py-3 bg-buffalo-primary text-white font-bold rounded-xl hover:bg-buffalo-secondary transition-colors"
        >
          See House Rules
        </a>
      </div>

      <SafetyBanner />
    </div>
  </section>
</BaseLayout>
