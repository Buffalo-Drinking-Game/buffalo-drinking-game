---
import '../styles/global.css';
import Header from '../components/Header';
import Footer from '../components/Footer';
import AgeGate from '../components/AgeGate';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Buffalo is a drinking game where you must drink with your non-dominant hand. The definitive guide to rules, variations, and etiquette.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/images/logo-transparent-small.png" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/images/buffalo-gh-social-card.png" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <AgeGate client:load>
      <Header client:load />
      <main class="flex-1">
        <slot />
      </main>
      <Footer />
    </AgeGate>
  </body>
</html>
